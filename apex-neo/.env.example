# Apex NEO Configuration
# Copy to .env and fill in your values

# --- Exchange (Binance) ---
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
TESTNET=true

# --- Trading Mode ---
# observe = read-only signal logging (default, safe)
# paper   = simulated fills
# live    = real orders (requires confirmation prompt)
MODE=observe

# --- Capital ---
CAPITAL=22.0
LEVERAGE=5
MAX_POSITION_PCT=0.90

# --- Risk ---
MAX_DRAWDOWN_PCT=4.0
PAUSE_DURATION_S=1800
EQUITY_FLOOR_PCT=50.0

# --- Telegram ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
JOURNAL_PATH=data/trades.jsonl
STATE_PATH=data/state.json

# --- Advanced Tuning (usually leave defaults) ---
# PRIMARY_PAIR=BTC/USDT
# MARKET_TYPE=future
# MIN_CONFIDENCE=0.70
# MIN_HOLD_S=15.0
# STOP_LOSS_PCT=0.12
# TRAIL_BASE_PCT=0.06
# TRAIL_MAX_PCT=0.12
# DECEL_THRESHOLD=0.20
# COOLDOWN_S=60.0
# REGIME_THRESHOLD=55.0
# TICK_INTERVAL_S=1.0
# BYBIT_ENABLED=true
